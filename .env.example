# ─────────────────────────────────────────────────────────────
# AURUM — environment configuration
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection.
# URL-encode any special characters in the password (e.g. # -> %23).
#
# • LOCAL: point both variables at your local database (same value).
# • NEON / serverless (Vercel): set DATABASE_URL to the POOLED connection
#   string (host contains "-pooler", add ?sslmode=require) and DIRECT_URL to
#   the DIRECT (non-pooled) string. `prisma db push` uses DIRECT_URL.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/aurum?schema=public"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/aurum?schema=public"

# Auth.js / NextAuth — generate a secret with: openssl rand -base64 32
AUTH_SECRET="change-me"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Claude API key (optional). Enables the real Claude analyst for AI Insights.
# Get one at https://console.anthropic.com. Leave empty to skip.
ANTHROPIC_API_KEY=""

# Google Gemini API key (optional, FREE — no credit card).
# Get one at https://aistudio.google.com/apikey.
# Used only when ANTHROPIC_API_KEY is empty.
# If BOTH keys are empty, AI Insights fall back to a transparent, deterministic
# heuristic analyst — so the app always works end-to-end.
GEMINI_API_KEY=""

# Optional: override the model used for AI Insights.
# INSIGHTS_MODEL="claude-sonnet-5"     # Claude  (when ANTHROPIC_API_KEY is set)
# GEMINI_MODEL="gemini-flash-latest"   # Gemini  (when GEMINI_API_KEY is set)
